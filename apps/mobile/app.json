{
  "expo": {
    "name": "philcoino",
    "slug": "philcoino",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/philcoino-icon.png",
    "scheme": "philcoino",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "6",
      "bundleIdentifier": "dev.viniciuslab.philcoino",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSLocalNetworkUsageDescription": "Philcoino uses your local network to discover and connect to your espresso machine.",
        "NSBonjourServices": [
          "_philcoino._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "CFBundleLocalizations": [
          "en",
          "pt-BR"
        ]
      },
      "appleTeamId": "637UA2N8TU"
    },
    "locales": {
      "en": "./locales/en.json",
      "pt-BR": "./locales/pt-BR.json"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/philcoino-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "dev.viniciuslab.philcoino",
      "versionCode": 6,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_MULTICAST_STATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/philcoino-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "pt-BR"
            ],
            "android": [
              "en",
              "pt-BR"
            ]
          }
        }
      ],
      [
        "./plugins/with-android-locale-resource-qualifiers",
        {
          "supportedLocales": [
            "en",
            "pt-BR"
          ]
        }
      ],
      "./plugins/with-android-cleartext",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/philcoino-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
